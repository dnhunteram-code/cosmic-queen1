{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",

  "appId": "com.cosmicqueen.app",

  "productName": "Cosmic Queen",

  "asar": true,

  "directories": {
    "output": "release/${version}"
  },

  "files": [
    "dist",
    "dist-electron"
  ],

  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "build/cosmic_256_multi.ico",
    "artifactName": "Cosmic Queen Setup.${ext}"
  },

  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    ],
    "icon": "build/cosmic.icns",
    "artifactName": "Cosmic Queen.${ext}",
    "category": "public.app-category.entertainment"
  },

  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Cosmic Queen"
  }
}